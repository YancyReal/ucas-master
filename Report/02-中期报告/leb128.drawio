        <mxCell id="slowBox" value="原版实现 (Slow Path)" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;rounded=1;" parent="1" vertex="1">
          <mxGeometry x="30" y="85" width="220" height="195" as="geometry" />
        </mxCell>
        <mxCell id="slowCode" value="&lt;font face=&quot;Courier New&quot;&gt;while (true) {&lt;br&gt;&amp;nbsp; if (ptr &amp;gt;= end) // ⚠️检查越界&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp; return error;&lt;br&gt;&amp;nbsp; byte = *ptr++;&lt;br&gt;&amp;nbsp; result |= ...;&lt;br&gt;&amp;nbsp; if (byte &amp;amp; 0x80 == 0)&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp; break; // ⚠️跳转循环是否结束&lt;br&gt;}&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=#ffffff;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;whiteSpace=wrap;fontSize=11;" parent="slowBox" vertex="1">
          <mxGeometry y="30" width="220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="slowPain" value="&amp;nbsp;每字节都检查边界+循环跳转" style="text;html=1;strokeColor=none;fillColor=#ffcccc;align=center;verticalAlign=middle;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;whiteSpace=wrap;fontSize=11;fontStyle=1;fontColor=#b85450;" parent="slowBox" vertex="1">
          <mxGeometry y="150" width="220" height="45" as="geometry" />
        </mxCell>
        <mxCell id="fastBox" value=" 优化实现 (Fast Path)" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;rounded=1;" parent="1" vertex="1">
          <mxGeometry x="560" y="85" width="230" height="195" as="geometry" />
        </mxCell>
        <mxCell id="fastCode" value="&lt;font face=&quot;Courier New&quot;&gt;if (ptr + 5 &amp;lt;= end) { // ✓一次检查&lt;br&gt;&amp;nbsp; b1 = *ptr++; if (done) return;&lt;br&gt;&amp;nbsp; b2 = *ptr++; if (done) return;&lt;br&gt;&amp;nbsp; b3 = *ptr++; if (done) return;&lt;br&gt;&amp;nbsp; ... // ✓线性展开&lt;br&gt;}&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=#ffffff;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;whiteSpace=wrap;fontSize=11;" parent="fastBox" vertex="1">
