        <mxCell id="subtitle" value="&lt;b&gt;核心思想：&lt;/b&gt;赌大概率事件，减少安全检查" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontColor=#e94560;" parent="1" vertex="1">
