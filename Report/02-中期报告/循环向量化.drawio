        <mxCell id="39" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;b style=&quot;&quot;&gt;典型应用场景&lt;/b&gt;&lt;br&gt;图像/视频处理、音频编解码&lt;br&gt;矩阵运算、快速傅里叶变换 (FFT)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#FFD966;fontSize=9;align=center;whiteSpace=wrap;" parent="1" vertex="1">
