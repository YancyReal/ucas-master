      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2" value="循环向量化优化 (Loop Vectorization) - Android ART Runtime 性能优化技术" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#B3D9FF;strokeColor=#6C8EBF;fontSize=13;fontStyle=1;align=center;" parent="1" vertex="1">
          <mxGeometry x="10" y="10" width="780" height="32" as="geometry" />
        </mxCell>
        <mxCell id="3" value="优化前：标量处理" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFD9D9;strokeColor=#CC9999;fontSize=12;fontStyle=1;align=center;" parent="1" vertex="1">
          <mxGeometry x="10" y="52" width="380" height="35" as="geometry" />
        </mxCell>
        <mxCell id="4" value="优化后：SIMD 向量化" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D9F2D9;strokeColor=#82B366;fontSize=12;fontStyle=1;align=center;" parent="1" vertex="1">
          <mxGeometry x="410" y="52" width="380" height="35" as="geometry" />
        </mxCell>
        <mxCell id="5" value="&lt;font&gt;for (i = 0; i &amp;lt; 8; i++) {&lt;br&gt;&amp;nbsp; array[i] = array[i] * 2;&lt;br&gt;}&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#FFD966;fontSize=10;align=left;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="15" y="97" width="165" height="55" as="geometry" />
        </mxCell>
        <mxCell id="6" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;这个元素串行处理&lt;br&gt;每次处理 1 个数据&lt;br&gt;执行 8 次循环&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=center;" parent="1" vertex="1">
          <mxGeometry x="190" y="97" width="195" height="55" as="geometry" />
        </mxCell>
        <mxCell id="7" value="for (i = 0; i &amp;lt; 8; i += 4) {&lt;br&gt;&amp;nbsp; vec_mul(array[i:i+4], 2);&lt;br&gt;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#93C47D;fontSize=10;align=left;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="415" y="97" width="175" height="55" as="geometry" />
        </mxCell>
        <mxCell id="8" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;4个元素并行处理&lt;br&gt;每次处理 4 个数据&lt;br&gt;只需 2 次循环 🔧&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D9EAD3;strokeColor=#93C47D;fontSize=10;align=center;" parent="1" vertex="1">
          <mxGeometry x="600" y="97" width="185" height="55" as="geometry" />
        </mxCell>
        <mxCell id="9" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;开始&lt;br&gt;i=0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9CC;strokeColor=#D6B656;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="15" y="167" width="50" height="35" as="geometry" />
        </mxCell>
        <mxCell id="10" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;读取&lt;br&gt;array[0]&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;fontSize=9;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="85" y="167" width="55" height="35" as="geometry" />
        </mxCell>
        <mxCell id="11" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;执行&lt;br&gt;* 2&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;fontSize=9;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="160" y="167" width="50" height="35" as="geometry" />
        </mxCell>
        <mxCell id="12" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;写回&lt;br&gt;array[0]&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;fontSize=9;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="230" y="167" width="55" height="35" as="geometry" />
