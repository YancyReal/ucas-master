        <mxCell id="13" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;i++&lt;br&gt;是否达到8&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4CC;strokeColor=#D6B656;fontSize=9;" parent="1" vertex="1">
