        </mxCell>
        <mxCell id="37" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;b style=&quot;&quot;&gt;ARM NEON/ LA LSX&lt;/b&gt;&lt;br&gt;128/256-bit 向量寄存器&lt;br&gt;支持整数/浮点运算&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;align=center;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="205" y="305" width="185" height="65" as="geometry" />
