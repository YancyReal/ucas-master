        <mxCell id="24" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;SIMD 读取&lt;br&gt;array[0:3]&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#64B5F6;fontSize=9;" parent="1" vertex="1">
