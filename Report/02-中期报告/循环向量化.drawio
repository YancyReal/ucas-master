        <mxCell id="38" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;b style=&quot;&quot;&gt;ART 编译器优化&lt;/b&gt;&lt;br&gt;自动检测可向量化循环&lt;br&gt;生成目标平台 SIMD 指令&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#64B5F6;fontSize=9;align=center;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="400" y="305" width="185" height="65" as="geometry" />
