        <mxCell id="36" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;b style=&quot;&quot;&gt;理论性能提升：2-16倍&lt;/b&gt;&lt;br&gt;向量宽度（4/816）&lt;br&gt;内存对齐&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D9F2D9;strokeColor=#82B366;fontSize=9;align=center;whiteSpace=wrap;" parent="1" vertex="1">
