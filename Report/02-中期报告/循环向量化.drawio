        <mxCell id="35" value="性能对比 &amp;amp; 关键技术" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6D9FF;strokeColor=#9673C4;fontSize=12;fontStyle=1;align=center;" parent="1" vertex="1">
